{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/lint-and-format.ps1",
        "timeout": 30,
        "failClosed": false
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/block-dangerous.ps1",
        "timeout": 10,
        "failClosed": true
      }
    ],
    "afterMCPExecution": [
      {
        "command": ".cursor/hooks/audit-mcp.ps1",
        "timeout": 10,
        "failClosed": false
      }
    ]
  }
}
