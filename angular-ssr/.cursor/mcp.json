{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "${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}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${POSTGRES_PRISMA_URL}"
      ]
    },
    "jira": {
      "url": "${JIRA_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${JIRA_MCP_TOKEN}"
      }
    },
    "atlassian-rovo": {
      "url": "${ATLASSIAN_ROVO_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${ATLASSIAN_ROVO_TOKEN}"
      }
    }
  }
}
