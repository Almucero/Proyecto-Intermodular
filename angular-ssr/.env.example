# URL PostgreSQL sin pool para operaciones que requieran conexión directa.
POSTGRES_URL_NON_POOLING=postgresql://neon_user:neon_password@neon_host_unpooled/neon_database?sslmode=require
# URL PostgreSQL principal usada por Prisma en runtime y tooling.
POSTGRES_PRISMA_URL=postgresql://neon_user:neon_password@neon_host_pooler/neon_database?connect_timeout=15&sslmode=require

# Puerto HTTP del servidor SSR + API en entorno local.
PORT=3000
# Entorno de ejecución de Node.js.
NODE_ENV=development
# Clave secreta usada para firmar y verificar JWT.
JWT_SECRET=supersecreta_cambia_esto
# Tiempo de expiración de los JWT.
JWT_EXPIRES_IN=7d
# Emisor esperado en los JWT.
JWT_ISSUER=game-sage
# Audiencia esperada en los JWT.
JWT_AUDIENCE=game-sage-users
# Orígenes permitidos por CORS en producción.
CORS_ORIGIN=https://only_in_production.com
# Coste de hash de bcrypt para contraseñas.
BCRYPT_SALT_ROUNDS=10

# Nombre de cloud de Cloudinary.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# API key pública de Cloudinary.
CLOUDINARY_API_KEY=your_cloudinary_api_key
# API secret privada de Cloudinary.
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Clave secreta de Stripe para backend y creación de sesiones.
STRIPE_SECRET_KEY=your_stripe_secret_key
# Clave pública de Stripe expuesta al frontend.
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# API key de Google Generative AI para el chat.
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key
# Client ID de Google OAuth para login/registro.
GOOGLE_CLIENT_ID=your_google_client_id
# Client ID de GitHub OAuth para login/registro.
GITHUB_CLIENT_ID=your_github_client_id
# Client secret de GitHub OAuth para backend.
GITHUB_CLIENT_SECRET=your_github_client_secret

# Correos de administradores iniciales separados por comas.
ADMIN_EMAILS=correo1@example.com,correo2@example.com
# Contraseñas iniciales de administradores separadas por comas y alineadas por posición.
ADMIN_PASSWORDS=password1,password2
# Nombres iniciales de administradores separados por comas y alineados por posición.
ADMIN_NAMES=user1,user2


# Cursor / MCP (Opcionales, solo si se usa Cursor y se quieren activar integraciones externas)
# En Windows, tras completar estas variables en `.env`, ejecutar:
# npm run setup:cursor-access
# Después, cerrar y volver a abrir Cursor.

# Token de GitHub para MCP GitHub.
GITHUB_TOKEN=your_github_token
# URL base de Jira Cloud (ej. https://tu-dominio.atlassian.net).
JIRA_URL=your_jira_url
# Email de acceso a Jira/Atlassian.
JIRA_USERNAME=your_jira_username
# API token de Atlassian para el MCP local de Jira.
JIRA_API_TOKEN=your_jira_api_token
