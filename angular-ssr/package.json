{
  "name": "game-sage",
  "version": "0.0.0",
  "scripts": {
    "ng": "node scripts/check-toolchain.mjs && ng",
    "start": "node scripts/free-port.mjs 4200 && node scripts/check-toolchain.mjs && ng serve",
    "start:ssr": "npm run serve:ssr:prod",
    "build": "node scripts/check-toolchain.mjs && cross-env NODE_OPTIONS=--max-old-space-size=8192 ng build",
    "build:ssr": "node scripts/check-toolchain.mjs && node scripts/check-prisma.mjs && cross-env SSR_DISABLE_BACKEND=1 NODE_OPTIONS=--max-old-space-size=8192 ng build",
    "build:full": "node scripts/check-toolchain.mjs && npx prisma generate && npm run seed:admin && npm run build:ssr",
    "serve:ssr": "npm run dev:ssr",
    "serve:ssr:https": "npm run dev:ssr:https",
    "serve:ssr:prod": "node scripts/free-port.mjs 3000 && node scripts/check-toolchain.mjs && node scripts/serve-ssr.mjs",
    "serve:ssr:watch": "nodemon -C --quiet --delay 4500ms --watch dist/game-sage/server --ext mjs --exec \"node --max-old-space-size=8192 --disable-warning=DEP0169 dist/game-sage/server/server.mjs\"",
    "dev:ssr": "node scripts/free-port.mjs 3000 && node scripts/check-toolchain.mjs && node scripts/dev-ssr.mjs",
    "dev:ssr:https": "node scripts/free-port.mjs 3000 && node scripts/free-port.mjs 3443 && node scripts/check-toolchain.mjs && cross-env DEV_SSL_PROXY=1 node scripts/dev-ssr.mjs",
    "dev": "node scripts/free-port.mjs 3000 && npm run dev:backend",
    "dev:backend": "node scripts/free-port.mjs 3000 && node scripts/check-toolchain.mjs && nodemon --config nodemon.backend.json",
    "watch": "node scripts/check-toolchain.mjs && ng build --watch --configuration development --progress=false",
    "test": "npm run test:backend",
    "test:frontend": "node scripts/check-toolchain.mjs && ng test",
    "test:backend": "node scripts/check-toolchain.mjs && cross-env NODE_ENV=test NODE_NO_WARNINGS=1 NODE_OPTIONS=--experimental-vm-modules jest --config jest.backend.config.js",
    "seed:admin": "node scripts/check-toolchain.mjs && tsx src/backend/scripts/seedAdmin.ts",
    "clean:data": "node scripts/check-toolchain.mjs && tsx src/backend/scripts/cleanData.ts",
    "seed:data": "node scripts/check-toolchain.mjs && npm run clean:data && tsx src/backend/scripts/seedData.ts",
    "format": "node scripts/check-toolchain.mjs && npx prettier --write \"**/*.{ts,js,html,css,json}\"",
    "clean": "node scripts/check-toolchain.mjs && npx rimraf dist logs coverage",
    "clean:full": "npx rimraf dist node_modules logs coverage docs documentation .venv",
    "reinstall": "npm run clean:full && npm install",
    "audit": "node scripts/check-toolchain.mjs && npm audit --audit-level=high --omit=dev",
    "audit:fix:prod": "npm audit fix --omit=dev && npm install --include=dev --no-audit --loglevel=error && npm audit --omit=dev",
    "setup:secure": "npm install --include=dev --no-audit --loglevel=error && npm run audit:fix:prod",
    "lint": "eslint src",
    "vercel-build": "node scripts/check-toolchain.mjs && npx prisma generate && npm run docs:build && npm run swagger:generate && npm run build:ssr && node scripts/copy-swagger-generated.mjs && node scripts/copy-docs-to-browser.mjs",
    "swagger:generate": "node scripts/check-toolchain.mjs && tsx scripts/generate-swagger-spec.ts",
    "postinstall": "npx prisma generate",
    "docs": "npm run docs:serve",
    "docs:serve": "compodoc -p tsconfig.doc.json -s --output docs",
    "docs:build": "compodoc -p tsconfig.doc.json --output docs"
  },
  "private": true,
  "dependencies": {
    "@ai-sdk/google": "^2.0.46",
    "@angular/animations": "20.3.19",
    "@angular/common": "20.3.19",
    "@angular/compiler": "20.3.19",
    "@angular/core": "20.3.19",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "20.3.19",
    "@angular/platform-browser": "20.3.19",
    "@angular/platform-browser-dynamic": "20.3.19",
    "@angular/platform-server": "20.3.19",
    "@angular/router": "20.3.19",
    "@angular/ssr": "20.3.24",
    "@google/generative-ai": "^0.24.1",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@prisma/client": "6.19.3",
    "@stripe/stripe-js": "^9.2.0",
    "@types/jsonwebtoken": "^9.0.10",
    "ai": "^5.0.112",
    "bcryptjs": "^2.4.3",
    "bootstrap": "5.3.3",
    "bootstrap-icons": "^1.13.1",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "firebase": "^11.10.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "imagemagick": "^0.1.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.5",
    "p-limit": "^7.2.0",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "stripe": "^22.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.3.0",
    "winston": "^3.18.3",
    "zod": "^3.24.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.24",
    "@angular/cli": "20.3.24",
    "@angular/compiler-cli": "20.3.19",
    "@compodoc/compodoc": "^1.2.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/hpp": "^0.2.7",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.17.19",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/parser": "^8.56.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-plugin-security": "^4.0.0",
    "http-proxy-middleware": "^3.0.5",
    "jasmine-core": "~5.6.0",
    "jest": "^30.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "kill-port": "^2.0.1",
    "local-ssl-proxy": "^2.0.5",
    "nodemon": "^3.1.11",
    "prisma": "6.19.3",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.18",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "follow-redirects": "^1.15.12",
    "beasties": "^0.3.3",
    "minimatch": "^10.2.1",
    "glob": "^13.0.0",
    "rimraf": "^5.0.0",
    "karma": {
      "rimraf": "^5.0.0"
    },
    "@compodoc/compodoc": {
      "ajv": "^8.18.0"
    },
    "prisma": "6.19.3",
    "picomatch": "^4.0.4",
    "lodash.get": "npm:lodash@^4.17.21",
    "lodash.isequal": "npm:lodash@^4.17.21",
    "protobufjs": "^7.5.5"
  }
}
