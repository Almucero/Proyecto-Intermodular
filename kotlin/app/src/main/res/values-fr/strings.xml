    <string name="privacy_title">Politique de Confidentialité</string>
    <string name="privacy_update">Date d\'entrée en vigueur : Décembre 2024</string>
    <string name="privacy_intro">Chez GameSage, votre confidentialité est importante pour nous.</string>
    
    <string name="conditions_title">Conditions Générales</string>
    <string name="conditions_update">Date d\'entrée en vigueur : Décembre 2024</string>
    <string name="conditions_intro">Bienvenue chez GameSage. En utilisant nos services, vous acceptez ces conditions.</string>
    <string name="conditions_section1_title">1. Acceptation des Conditions</string>
    <string name="conditions_section1_text">En accédant et en utilisant GameSage, vous acceptez de respecter ces conditions générales.</string>
    <string name="conditions_section2_title">2. Utilisation du Service</string>
    <string name="conditions_section2_text">Vous devez utiliser GameSage de manière responsable et légale. Non autorisé :</string>
    <string name="conditions_section2_bp1">Utiliser le service pour des activités illégales</string>
    <string name="conditions_section2_bp2">Tenter d\'accéder aux comptes d\'autres utilisateurs</string>
    <string name="conditions_section2_bp3">Distribuer des logiciels malveillants ou du contenu nuisible</string>
    <string name="conditions_section2_bp4">Rétro-ingénierie du service</string>
    <string name="conditions_section3_title">3. Comptes Utilisateurs</string>
    <string name="conditions_section3_text">Vous êtes responsable de maintenir la confidentialité de votre compte et de votre mot de passe.</string>
    <string name="conditions_section4_title">4. Achats et Paiements</string>
    <string name="conditions_section4_text">Tous les prix sont en Euros et incluent la TVA. Les achats sont définitifs sauf indication contraire.</string>
    <string name="conditions_section5_title">5. Propriété Intellectuelle</string>
    <string name="conditions_section5_text">Tout le contenu de GameSage est protégé par le droit d\'auteur et d\'autres lois sur la propriété intellectuelle.</string>
    <string name="conditions_section6_title">6. Limitation de Responsabilité</string>
    <string name="conditions_section6_text">GameSage n\'est pas responsable des dommages indirects, accessoires ou consécutifs résultant de l\'utilisation du service.</string>
    <string name="conditions_section7_title">7. Modifications</string>
    <string name="conditions_section7_text">Nous nous réservons le droit de modifier ces conditions à tout moment.</string>
    <string name="conditions_section8_title">8. Contact</string>
    <string name="conditions_section8_text">Pour des questions sur ces conditions, contactez-nous à info.gamesage@gmail.com</string>

    <string name="cookies_section1_title">1. Que sont les cookies ?</string>
    <string name="cookies_section1_text">Les cookies sont de petits fichiers texte stockés sur votre appareil lorsque vous visitez un site Web.</string>
    <string name="cookies_section2_title">2. Types de cookies que nous utilisons</string>
    <string name="cookies_type_essential_title">Cookies Essentiels</string>
    <string name="cookies_type_essential_desc">Nécessaires pour le fonctionnement de base du site Web.</string>
    <string name="cookies_type_pref_title">Cookies de Préférence</string>
    <string name="cookies_type_pref_desc">Mémorisent vos préférences telles que la langue et les paramètres.</string>
    <string name="cookies_type_analytics_title">Cookies Analytiques</string>
    <string name="cookies_type_analytics_desc">Nous aident à comprendre comment vous utilisez le site pour l\'améliorer.</string>
    <string name="cookies_type_marketing_title">Cookies Marketing</string>
    <string name="cookies_type_marketing_desc">Personnalisent les publicités en fonction de vos intérêts.</string>
    <string name="cookies_section3_title">3. Gestion des cookies</string>
    <string name="cookies_section3_text">Vous pouvez configurer votre navigateur pour refuser les cookies, mais cela peut affecter la fonctionnalité du site.</string>
    <string name="cookies_section4_title">4. Plus d\'informations</string>
    <string name="cookies_section4_text">Pour plus d\'informations sur notre politique de cookies, contactez-nous à info.gamesage@gmail.com</string>

    <string name="privacy_section1_title">1. Informations que nous collectons</string>
    <string name="privacy_section1_text">Nous collectons les informations suivantes :</string>
    <string name="privacy_section1_bp1">Nom et adresse e-mail</string>
    <string name="privacy_section1_bp2">Informations de paiement (traitées en toute sécurité)</string>
    <string name="privacy_section1_bp3">Historique des achats et préférences</string>
    <string name="privacy_section1_bp4">Données d\'utilisation et de navigation</string>
    <string name="privacy_section1_bp5">Adresse IP et données de l\'appareil</string>
    <string name="privacy_section2_title">2. Comment nous utilisons vos informations</string>
    <string name="privacy_section2_text">Nous utilisons vos informations pour :</string>
    <string name="privacy_section2_bp1">Traiter vos commandes et transactions</string>
    <string name="privacy_section2_bp2">Améliorer nos services</string>
    <string name="privacy_section2_bp3">Vous envoyer des mises à jour et des offres (avec votre consentement)</string>
    <string name="privacy_section2_bp4">Respecter les obligations légales</string>
    <string name="privacy_section2_bp5">Prévenir la fraude et assurer la sécurité</string>
    <string name="privacy_section3_title">3. Partage d\'informations</string>
    <string name="privacy_section3_text">Nous ne vendons pas vos informations personnelles. Nous les partageons uniquement avec :</string>
    <string name="privacy_section3_bp1">Fournisseurs de services de paiement</string>
    <string name="privacy_section3_bp2">Services d\'analyse et de marketing</string>
    <string name="privacy_section3_bp3">Autorités lorsque requis par la loi</string>
    <string name="privacy_section4_title">4. Sécurité des données</string>
    <string name="privacy_section4_text">Nous mettons en œuvre des mesures de sécurité techniques et organisationnelles pour protéger vos informations.</string>
    <string name="privacy_section5_title">5. Vos droits</string>
    <string name="privacy_section5_text">Vous avez le droit de :</string>
    <string name="privacy_section5_bp1">Accéder à vos données personnelles</string>
    <string name="privacy_section5_bp2">Rectifier les informations incorrectes</string>
    <string name="privacy_section5_bp3">Demander la suppression de vos données</string>
    <string name="privacy_section5_bp4">Vous opposer au traitement de vos données</string>
    <string name="privacy_section5_bp5">Portabilité des données</string>
    <string name="privacy_section6_title">6. Cookies</string>
    <string name="privacy_section6_text">Nous utilisons des cookies pour améliorer votre expérience. Voir notre Politique de Cookies pour plus d\'informations.</string>
    <string name="privacy_section7_title">7. Modifications de cette politique</string>
    <string name="privacy_section7_text">Nous pouvons mettre à jour cette politique occasionnellement. Nous vous informerons des modifications importantes.</string>
    <string name="privacy_section8_title">8. Contact</string>
    <string name="privacy_section8_text">Pour exercer vos droits ou poser des questions sur la confidentialité, contactez-nous à info.gamesage@gmail.com</string>

